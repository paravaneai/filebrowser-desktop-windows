<Window x:Class="FileBrowserDesktop.OnboardingWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Browser Desktop Setup"
        Width="780"
        Height="760"
        MinWidth="720"
        MinHeight="680"
        WindowStartupLocation="CenterOwner"
        Background="#F6F7F9">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Set Up File Browser Desktop"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#111827" />
            <TextBlock Margin="0,6,0,16"
                       Foreground="#475569"
                       TextWrapping="Wrap"
                       Text="Create a connection profile, optionally configure File Browser on the server, then test SSH and the tunnel before opening the desktop app." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="14"
                        Background="#FFFFFF"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Setup Path"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <RadioButton x:Name="ExistingRadioButton"
                                     Margin="0,10,0,4"
                                     IsChecked="True"
                                     Checked="SetupPathRadioButton_Checked"
                                     Content="Connect to existing File Browser" />
                        <RadioButton x:Name="InstallRadioButton"
                                     Margin="0,0,0,0"
                                     Checked="SetupPathRadioButton_Checked"
                                     Content="Help me install/configure File Browser on the server" />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="#FFFFFF"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="3" Margin="0,0,0,12" Text="Connection Profile" FontWeight="SemiBold" Foreground="#111827" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Profile name" />
                        <TextBox x:Name="NameTextBox" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="My Server" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="SSH username" />
                        <TextBox x:Name="SshUserTextBox" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="SSH host" />
                        <TextBox x:Name="SshHostTextBox" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="SSH port" />
                        <TextBox x:Name="SshPortTextBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="22" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="SSH key file" />
                        <TextBox x:Name="SshIdentityFileTextBox" Grid.Row="5" Grid.Column="1" Margin="0,0,8,10" ToolTip="Optional. Leave blank to use SSH config, default keys, or ssh-agent." />
                        <Button Grid.Row="5" Grid.Column="2" Width="74" Margin="0,0,0,10" Content="Browse" Click="BrowseIdentityFileButton_Click" />

                        <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Local port" />
                        <TextBox x:Name="LocalPortTextBox" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="18080" />

                        <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Remote File Browser host" />
                        <TextBox x:Name="RemoteHostTextBox" Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="127.0.0.1" />

                        <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Remote File Browser port" />
                        <TextBox x:Name="RemotePortTextBox" Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2" Margin="0,0,0,10" Text="8080" />

                        <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" Text="Server root" />
                        <TextBox x:Name="ServerRootTextBox" Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="2" Text="/" ToolTip="Only used by the install/configure path." />
                    </Grid>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="#FFFFFF"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Server Setup"
                                   FontWeight="SemiBold"
                                   Foreground="#111827" />
                        <CheckBox x:Name="AlreadyInstalledCheckBox"
                                  Margin="0,10,0,0"
                                  Content="File Browser is already installed; only configure service/bind address" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#475569"
                                   TextWrapping="Wrap"
                                   Text="Install/configure runs the bundled safe server script over SSH. It binds File Browser to localhost and does not open firewall ports. Non-root users need passwordless sudo for this step." />
                    </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="14"
                        Background="#FFFFFF"
                        BorderBrush="#D8DEE8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <WrapPanel Grid.Row="0">
                            <Button x:Name="TestSshButton" Width="110" Height="32" Margin="0,0,8,8" Content="Test SSH" Click="TestSshButton_Click" />
                            <Button x:Name="InstallButton" Width="150" Height="32" Margin="0,0,8,8" Content="Install/Configure" Click="InstallButton_Click" />
                            <Button x:Name="TestTunnelButton" Width="110" Height="32" Margin="0,0,8,8" Content="Test Tunnel" Click="TestTunnelButton_Click" />
                        </WrapPanel>
                        <TextBox x:Name="LogTextBox"
                                 Grid.Row="1"
                                 Height="150"
                                 Margin="0,8,0,0"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas"
                                 FontSize="12" />
                    </Grid>
                </Border>

                <TextBlock x:Name="ErrorText"
                           Margin="0,12,0,0"
                           Foreground="#DC2626"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,14,0,0" LastChildFill="False">
            <Button Content="Cancel"
                    Width="88"
                    Height="32"
                    Margin="0,0,8,0"
                    Click="CancelButton_Click"
                    DockPanel.Dock="Right" />
            <Button x:Name="SaveOpenButton"
                    Content="Save &amp;&amp; Open"
                    Width="108"
                    Height="32"
                    IsDefault="True"
                    Click="SaveOpenButton_Click"
                    DockPanel.Dock="Right" />
        </DockPanel>
    </Grid>
</Window>
