<Window x:Class="FileBrowserDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="File Browser Desktop"
        MinHeight="560"
        MinWidth="860"
        Height="760"
        Width="1180"
        SourceInitialized="Window_SourceInitialized"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Background="#F6F7F9">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#111827" />
        <SolidColorBrush x:Key="DisabledTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#F2F4F7" />
        <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="#E7ECF3" />
        <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="#DCE4EF" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D4DAE4" />
        <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#EEF2F7" />
        <SolidColorBrush x:Key="DisabledBorderBrush" Color="#DCE3EC" />
        <SolidColorBrush x:Key="SwitchBackgroundBrush" Color="#D7DEE8" />
        <SolidColorBrush x:Key="SwitchCheckedBackgroundBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="SwitchThumbBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="SwitchHoverBorderBrush" Color="#93C5FD" />

        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type ButtonBase}">
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ButtonBase}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource ControlPressedBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource DisabledTextBrush}" />
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="{DynamicResource DisabledBorderBrush}" />
                                <Setter Property="Opacity" Value="1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeSwitchStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Width" Value="78" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SwitchBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid>
                            <Border x:Name="Track"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center" />
                            <Ellipse x:Name="Thumb"
                                     Width="18"
                                     Height="18"
                                     Margin="4,0,0,0"
                                     HorizontalAlignment="Left"
                                     Fill="{DynamicResource SwitchThumbBrush}"
                                     VerticalAlignment="Center" />
                            <TextBlock x:Name="SwitchLabel"
                                       Margin="28,0,10,0"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{TemplateBinding Foreground}"
                                       Text="Light" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{DynamicResource SwitchCheckedBackgroundBrush}" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,4,0" />
                                <Setter TargetName="SwitchLabel" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="SwitchLabel" Property="Margin" Value="10,0,28,0" />
                                <Setter TargetName="SwitchLabel" Property="Text" Value="Dark" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource SwitchHoverBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBar"
                Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,0,0,1">
            <Grid Margin="12,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Image x:Name="AppLogo"
                       Grid.Column="0"
                       Width="24"
                       Height="24"
                       Margin="0,0,12,0"
                       VerticalAlignment="Center"
                       Source="Assets/filebrowser.ico" />

                <ComboBox x:Name="ProfileComboBox"
                          Grid.Column="1"
                          Width="180"
                          Height="32"
                          Margin="0,0,6,0"
                          SelectionChanged="ProfileComboBox_SelectionChanged"
                          ToolTip="Connection profile" />

                <Button x:Name="NewProfileButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="2"
                        MinWidth="48"
                        Margin="0,0,6,0"
                        Click="NewProfileButton_Click"
                        Content="New" />

                <Button x:Name="EditProfileButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="3"
                        MinWidth="48"
                        Margin="0,0,12,0"
                        Click="EditProfileButton_Click"
                        Content="Edit" />

                <Button x:Name="BackButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="4"
                        Width="36"
                        Margin="0,0,6,0"
                        Click="BackButton_Click"
                        ToolTip="Back"
                        Content="‹"
                        FontSize="22"
                        FontWeight="SemiBold" />

                <Button x:Name="ForwardButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="5"
                        Width="36"
                        Margin="0,0,6,0"
                        Click="ForwardButton_Click"
                        ToolTip="Forward"
                        Content="›"
                        FontSize="22"
                        FontWeight="SemiBold" />

                <Button x:Name="ReloadButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="6"
                        Width="36"
                        Margin="0,0,6,0"
                        Click="ReloadButton_Click"
                        ToolTip="Reload"
                        Content="↻"
                        FontSize="17" />

                <Button x:Name="HomeButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="7"
                        Width="36"
                        Margin="0,0,12,0"
                        Click="HomeButton_Click"
                        ToolTip="Home"
                        Content="⌂"
                        FontSize="16" />

                <Border x:Name="AddressBox"
                        Grid.Column="8"
                        Height="32"
                        Background="#F2F4F7"
                        BorderBrush="#D4DAE4"
                        BorderThickness="1"
                        CornerRadius="4"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="AddressText"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Foreground="#334155"
                               FontSize="13"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <ToggleButton x:Name="ThemeToggleButton"
                              Style="{StaticResource ThemeSwitchStyle}"
                              Grid.Column="9"
                              Margin="12,0,0,0"
                              Checked="ThemeToggleButton_Checked"
                              Unchecked="ThemeToggleButton_Unchecked"
                              ToolTip="Switch theme" />

                <Button x:Name="ReconnectButton"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Grid.Column="10"
                        MinWidth="84"
                        Margin="12,0,0,0"
                        Click="ReconnectButton_Click"
                        Content="Reconnect" />
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <wv2:WebView2 x:Name="Browser"
                          NavigationStarting="Browser_NavigationStarting"
                          NavigationCompleted="Browser_NavigationCompleted" />

            <Border x:Name="StartupOverlay"
                    Background="#F6F7F9">
                <StackPanel Width="440"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image x:Name="StartupLogo"
                           Width="56"
                           Height="56"
                           Margin="0,0,0,14"
                           Source="Assets/filebrowser.ico" />
                    <TextBlock x:Name="StartupTitleText"
                               Text="File Browser Desktop"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="#111827"
                               HorizontalAlignment="Center" />
                    <TextBlock x:Name="StartupStatusText"
                               Margin="0,14,0,0"
                               Text="Starting SSH tunnel..."
                               FontSize="15"
                               Foreground="#475569"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <ProgressBar Margin="0,22,0,0"
                                 Height="6"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </Grid>

        <Border x:Name="StatusBar"
                Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="#D8DEE8"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,7">
                <Ellipse x:Name="StatusDot"
                         Width="9"
                         Height="9"
                         Margin="0,0,8,0"
                         Fill="#F59E0B"
                         VerticalAlignment="Center" />
                <TextBlock x:Name="StatusText"
                           Foreground="#475569"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="Starting..." />
            </DockPanel>
        </Border>
    </Grid>
</Window>
